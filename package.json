{
  "name": "image-simple-panel",
  "version": "0.1.0",
  "description": "Local image generation panel for gpt-image-2 text-to-image and image-to-image workflows.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/CuiMuxuan/image-simple-panel.git"
  },
  "bugs": {
    "url": "https://github.com/CuiMuxuan/image-simple-panel/issues"
  },
  "homepage": "https://github.com/CuiMuxuan/image-simple-panel#readme",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:web": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "build:pages": "tsc -b && vite build --mode pages",
    "preview": "vite preview --host 127.0.0.1",
    "check": "tsc -b"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "axios": "^1.13.2",
    "concurrently": "^9.2.1",
    "express": "^5.2.1",
    "form-data": "^4.0.5",
    "lucide-react": "^0.562.0",
    "multer": "^2.0.2",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tsx": "^4.21.0",
    "vite": "^7.3.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.0.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3"
  }
}
